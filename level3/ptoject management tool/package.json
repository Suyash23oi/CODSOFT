{
  "name": "project-management-tool",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "install-all": "npm install --workspace=server && npm install --workspace=client",
    "start": "npm run start --workspace=server",
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
